# =================================================================
# 한국투자증권 & 깃허브 무한매수법 봇 환경 설정 파일
# =================================================================

# 1. 한국투자증권 [실전투자] 계좌 설정 (Real)
REAL_KIS_APPKEY=your_real_appkey_here
REAL_KIS_APPSECRET=your_real_appsecret_here
REAL_KIS_CANO=your_real_cano_8_digits_here
REAL_KIS_ACNT_PRDT_CD=01

# 2. 한국투자증권 [모의투자] 계좌 설정 (Mock)
MOCK_KIS_APPKEY=your_mock_appkey_here
MOCK_KIS_APPSECRET=your_mock_appsecret_here
MOCK_KIS_CANO=your_mock_cano_8_digits_here
MOCK_KIS_ACNT_PRDT_CD=01

# 3. 기본 실행 환경 (mock: 모의투자, real: 실전투자)
KIS_ENVIRONMENT=mock

# 4. 깃허브 데이터베이스 (상태 저장용) 설정
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=your_github_username/your_repo_name_here
GITHUB_FILE_PATH=state.json
